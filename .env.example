# Port for the proxy server (default: 3000)
PORT=3000

# OpenAI API base URL (default: https://api.openai.com)
OPENAI_BASE_URL=https://api.openai.com

# grsai API base URL (default: https://grsaiapi.com)
# GRSAI_BASE_URL=https://grsaiapi.com

# KIE API base URL (default: https://api.kie.ai)
# KIE_BASE_URL=https://api.kie.ai

# Required prefix in Authorization token. Client sends: "Bearer <PROXY_AUTH_PREFIX>:<API_KEY>"
# If empty, any Bearer token is accepted (dev only).
PROXY_AUTH_PREFIX=myFeedproxy3128

# API keys для тестов (npm run test)
OPENAI_API_KEY=sk-your-openai-key
GRSAI_API_KEY=sk-your-grsai-key
KIE_API_KEY=your-kie-api-key
