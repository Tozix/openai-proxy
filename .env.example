# Port for the proxy server (default: 3000)
PORT=3000

# OpenAI API base URL (default: https://api.openai.com)
OPENAI_BASE_URL=https://api.openai.com

# Required prefix in Authorization token. Client sends: "Bearer <PROXY_AUTH_PREFIX>:<OPENAI_API_KEY>"
# If empty, any Bearer token is accepted (dev only).
PROXY_AUTH_PREFIX=myproxy
