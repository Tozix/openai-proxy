# Пример виртуального хоста nginx для OpenAI Proxy.
# Скопируйте в /etc/nginx/sites-available/ (или conf.d), подставьте server_name и путь к сертификатам.
# Для HTTPS: certbot или свой сертификат.

# HTTP (редирект на HTTPS или оставить как есть для локальной сети)
server {
    listen 80;
    server_name api-proxy.example.com;

    location /v1/ {
        proxy_pass http://127.0.0.1:7388;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        # Стриминг (SSE) и долгие ответы
        proxy_buffering off;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
    }

    location /v1 {
        return 301 $scheme://$host/v1/;
    }
}

